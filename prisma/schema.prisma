generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CompanyInfo {
  id           String   @id @default(uuid())
  name         String
  description  String
  mission      String?
  vision       String?
  contactEmail String?
  phone        String?
  address      String?
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
}

enum ListingType {
  SALE
  RENT
}

enum PricePeriod {
  TOTAL
  MONTHLY
  YEARLY
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  SOLD
  RENTED
  ARCHIVED
}

enum CurrencyCode {
  NPR
  USD
}

enum AreaUnit {
  SQ_FT
  SQ_M
  AANA
  ROPANI
}

enum BadgeTone {
  NEUTRAL
  WARM
  COOL
}

enum FurnishingStatus {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum HouseSubType {
  BUNGALOW
  VILLA
  DUPLEX
  TOWNHOUSE
}

enum HouseUsageType {
  RESIDENTIAL
  COMMERCIAL
  SEMI_COMMERCIAL
}

enum ApartmentSubType {
  STUDIO
  APARTMENT
  PENTHOUSE
  CONDO
}

enum LandSubType {
  RESIDENTIAL_PLOT
  COMMERCIAL_LAND
  AGRICULTURAL_LAND
}

enum FacingDirection {
  EAST
  WEST
  NORTH
  SOUTH
  NORTH_EAST
  NORTH_WEST
  SOUTH_EAST
  SOUTH_WEST
}

enum InquiryType {
  GENERAL
  PROPERTY
  SCHEDULE_VISIT
  SELLER
}

enum InquiryStatus {
  NEW
  CONTACTED
  CLOSED
  SPAM
}

model Property {
  id           String         @id @default(uuid())
  title        String
  slug         String         @unique
  summary      String?
  description  String
  propertyType PropertyType
  listingType  ListingType
  priceAmount  Decimal        @db.Decimal(14, 2)
  currency     CurrencyCode   @default(NPR)
  pricePeriod  PricePeriod    @default(TOTAL)
  status       PropertyStatus @default(DRAFT)
  isFeatured   Boolean        @default(false)
  badgeLabel   String?
  badgeTone    BadgeTone?
  locationText String
  district     String?
  city         String?
  latitude     Decimal?       @db.Decimal(10, 7)
  longitude    Decimal?       @db.Decimal(10, 7)
  areaValue    Decimal?       @db.Decimal(12, 2)
  areaUnit     AreaUnit?

    titleStatus       String?   @default("Clear Lal Purja") 
  waterAvailability String? 
  electricity       String?   


isVerified        Boolean   @default(false)
  isOwnerApproved   Boolean   @default(false)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  videoUrl  String?
  mapIframe String? @db.Text

  houseDetails      HouseDetails?
  apartmentDetails  ApartmentDetails?
  landDetails       LandDetails?
  images            PropertyImage[]
  propertyAmenities PropertyAmenity[]
  inquiries         Inquiry[]

  @@index([propertyType, status])
  @@index([listingType, status])
  @@index([city, district])
  @@index([priceAmount])
  @@index([status, propertyType, listingType, priceAmount])
}

model HouseDetails {
  id               String            @id @default(uuid())
  propertyId       String            @unique
  property         Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  subType          HouseSubType
  usageType        HouseUsageType    @default(RESIDENTIAL)
  bedrooms         Int?
  bathrooms        Int?
  kitchens         Int?
  floors           Int?
  parkingSpaces    Int?
  furnishingStatus FurnishingStatus?
  buildYear        Int?
}

model ApartmentDetails {
  id               String            @id @default(uuid())
  propertyId       String            @unique
  property         Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  subType          ApartmentSubType
  bedrooms         Int?
  bathrooms        Int?
  balconies        Int?
  floorNumber      Int?
  totalFloors      Int?
  hasLift          Boolean           @default(false)
  hasParking       Boolean           @default(false)
  furnishingStatus FurnishingStatus?
}

model LandDetails {
  id              String           @id @default(uuid())
  propertyId      String           @unique
  property        Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  subType         LandSubType
  roadAccessFeet  Decimal?         @db.Decimal(8, 2)
  frontageFeet    Decimal?         @db.Decimal(8, 2)
  facingDirection FacingDirection?
  plotShape       String?
  zoningType      String?
  isCornerPlot    Boolean          @default(false)
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  altText    String?
  caption    String?
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([propertyId, sortOrder])
}

model Amenity {
  id                String            @id @default(uuid())
  name              String            @unique
  slug              String            @unique
  propertyAmenities PropertyAmenity[]
  createdAt         DateTime          @default(now())
}

model PropertyAmenity {
  propertyId String
  amenityId  String

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
  @@index([amenityId])
}

model Inquiry {
  id         String        @id @default(uuid())
  propertyId String?
  property   Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  type       InquiryType   @default(GENERAL)
  status     InquiryStatus @default(NEW)
  fullName   String
  email      String?
  phone      String?
  message    String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([propertyId, status])
}

enum LegalDocType {
  PRIVACY_POLICY
  COOKIE_POLICY
  TERMS_AND_CONDITIONS
}

model LegalDocument {
  id   String       @id @default(uuid())
  type LegalDocType @unique

  title   String
  content String? @db.Text

  version       String?
  effectiveDate DateTime?
  isActive      Boolean   @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("legal_documents")
}

model Newsletter {
  id         String  @id @default(uuid())
  email      String  @unique
  subscribed Boolean @default(true)
  name       String?
  country    String?
  source     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("newsletters")
}

enum FaqCategory {
  GENERAL
  LEGAL_AND_MALPOT
  TAXES_AND_FEES
  HOME_LOANS
  NRN_AND_EXPATS
  RENTING_AND_LEASES
  MEASUREMENTS
}

model Faq {
  id       String @id @default(uuid())
  question String
  answer   String @db.Text

  category    FaqCategory @default(GENERAL)
  sortOrder   Int         @default(0)
  isPublished Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}


model Affiliation {
  id           String   @id @default(cuid())
  name         String   
  logoUrl      String   
  isActive     Boolean  @default(true) 
  displayOrder Int      @default(0)    
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  location  String
  email     String   @unique
  bio       String
  expertise String[] 
  education String
  thumbnail String?  
  image     String?  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Review {
  id         String   @id @default(cuid())
  name       String
  role       String
  text       String   @db.Text 
  rating     Int      @default(5)
  isFeatured Boolean  @default(false)
  image      String?  
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}



model BlogArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String
  excerpt     String   @db.Text
  content     String   @db.Text 
  coverImage  String?
  
  author      String
  authorRole  String
  authorImage String?
  
  readTime    String   
  isFeatured  Boolean  @default(false)
  
  publishDate DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model SupportTicket {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  status    String   @default("OPEN") 
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
